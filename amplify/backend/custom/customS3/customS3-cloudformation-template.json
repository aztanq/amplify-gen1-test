{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Custom S3 bucket for Gen 1 testing",
  "Parameters": {
    "env": {
      "Type": "String"
    }
  },
  "Resources": {
    "CustomS3Bucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketName": {
          "Fn::Sub": "amplify-gen1-custom-bucket-${env}-${AWS::AccountId}"
        },
        "VersioningConfiguration": {
          "Status": "Enabled"
        }
      }
    }
  },
  "Outputs": {
    "BucketName": {
      "Value": {
        "Ref": "CustomS3Bucket"
      }
    }
  }
}
